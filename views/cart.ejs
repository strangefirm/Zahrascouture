<%- include('partials/header', { extraStyles: '/css/shop.css' }) %>

<div class="cart-page container">
    <div class="cart-header">
        <span class="section-tag">Shopping Bag</span>
        <h1>Review Your Cart</h1>
    </div>

    <div class="cart-layout" id="cartLayout">
        <!-- Main Cart List -->
        <div class="cart-items-container" id="cartItemsList">
            <!-- Rendered dynamically by JS -->
            <div class="cart-loading">Loading items in your bag...</div>
        </div>

        <!-- Summary Sidebar -->
        <div class="cart-summary" id="cartSummaryBox" style="display: none;">
            <h3>Order Summary</h3>
            <div class="summary-row">
                <span>Items Subtotal</span>
                <span id="summarySubtotal">₹0.00</span>
            </div>
            <div class="summary-row">
                <span>Estimated Shipping</span>
                <span id="summaryShipping" class="shipping-loading">Calculating...</span>
            </div>
            <div class="summary-row total-row">
                <span>Estimated Total</span>
                <span id="summaryTotal">₹0.00</span>
            </div>
            <p class="summary-note">Shipping calculated dynamically based on total order weight.</p>
            <a href="/checkout" class="btn btn-primary checkout-btn">
                Proceed to Checkout
            </a>
            <a href="/shop" class="continue-shopping">← Continue Shopping</a>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
