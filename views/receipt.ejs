<%- include('partials/header', { extraStyles: '/css/shop.css' }) %>

<div class="receipt-wrapper">
    <!-- Success Banner -->
    <div class="payment-success-banner no-print" style="display: flex; align-items: center; gap: 16px; background: rgba(37, 211, 102, 0.1); border: 1px solid rgba(37, 211, 102, 0.2); padding: 20px; border-radius: var(--radius-md); margin-bottom: var(--space-xl); color: var(--clr-whatsapp-dark);">
        <div class="success-icon" style="background: var(--clr-whatsapp); color: #fff; width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; box-shadow: 0 4px 12px rgba(37, 211, 102, 0.3);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
        </div>
        <div>
            <h2 style="font-family: var(--font-body); font-size: 1.25rem; font-weight: 700; color: var(--clr-whatsapp-dark); margin-bottom: 4px;">Payment Successful!</h2>
            <p style="font-size: 0.92rem; color: var(--clr-text); line-height: 1.45;">Thank you for shopping with Zahra's Couture. Your order is confirmed.</p>
        </div>
    </div>

    <!-- Receipt Watermark Stamp -->
    <div class="receipt-stamp">
        <div class="stamp-border" style="display: flex; flex-direction: column; align-items: center; justify-content: center; line-height: 1.2;">
            <span style="font-size: 1.3rem; font-weight: 800; letter-spacing: 0.05em;">PAID</span>
            <span style="font-size: 0.72rem; font-weight: 600; opacity: 0.85;"><%= new Date(order.created_at).toLocaleDateString('en-IN') %></span>
        </div>
    </div>

    <!-- Receipt Header -->
    <div class="invoice-header receipt-header">
        <div class="invoice-brand">
            Zahra's <span>Couture</span>
            <p style="font-family: var(--font-body); font-size: 0.88rem; font-weight: normal; color: var(--clr-text-muted); margin-top: 4px;">
                Premium Women's Ethnic Wear<br>
                Tamil Nadu, India<br>
                zahrascouture@gmail.com<br>
                +91 89391 90164
            </p>
        </div>
        <div class="invoice-title-block">
            <h1 style="color: var(--clr-whatsapp);">RECEIPT</h1>
            <p style="font-size: 0.9rem; color: var(--clr-text-muted);"><strong>Order No:</strong> <%= order.order_number %></p>
            <p style="font-size: 0.9rem; color: var(--clr-text-muted);"><strong>Date:</strong> <%= new Date(order.created_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) %></p>
            <p style="font-size: 0.9rem; color: var(--clr-text-muted);"><strong>Payment Status:</strong> <span class="badge badge-paid" style="display: inline-block; padding: 3px 8px; border-radius: 4px; font-size: 0.75rem; font-weight: bold; background: rgba(37, 211, 102, 0.15); color: var(--clr-whatsapp-dark);">PAID</span></p>
            <p style="font-size: 0.88rem; color: var(--clr-text-light); margin-top: 4px;"><strong>TXN ID:</strong> <%= order.payment_id %></p>
        </div>
    </div>

    <!-- Billing Info -->
    <div class="invoice-meta-grid">
        <div class="invoice-address-block">
            <h3>Shipped To:</h3>
            <p>
                <strong><%= order.customer_name %></strong><br>
                <%= order.customer_address %><br>
                <%= order.city %> - <%= order.pincode %><br>
                <strong>Phone:</strong> <%= order.customer_phone %>
                <% if (order.customer_email) { %><br><strong>Email:</strong> <%= order.customer_email %><% } %>
            </p>
        </div>
        <div class="invoice-address-block" style="text-align: right;">
            <h3>Payment Information:</h3>
            <p>
                Method: Razorpay Online<br>
                Status: Completed / Settled<br>
                Transaction currency: INR (₹)
            </p>
        </div>
    </div>

    <!-- Table of Items -->
    <table class="invoice-details-table">
        <thead>
            <tr>
                <th>Item Description</th>
                <th>Size</th>
                <th style="text-align: center;">Qty</th>
                <th style="text-align: right;">Unit Price</th>
                <th style="text-align: right;">Total</th>
            </tr>
        </thead>
        <tbody>
            <% order.items.forEach(item => { %>
                <tr>
                    <td><strong><%= item.product_name %></strong></td>
                    <td style="font-weight: 500;"><%= item.size %></td>
                    <td style="text-align: center;"><%= item.quantity %></td>
                    <td style="text-align: right;">₹<%= item.price.toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></td>
                    <td style="text-align: right; font-weight: 600;">₹<%= (item.price * item.quantity).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></td>
                </tr>
            <% }) %>
        </tbody>
    </table>

    <!-- Totals Section -->
    <div class="invoice-totals-section">
        <div class="invoice-totals-box">
            <div class="summary-row" style="display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 0.9rem; color: var(--clr-text-muted);">
                <span>Subtotal</span>
                <span>₹<%= order.subtotal.toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></span>
            </div>
            <div class="summary-row" style="display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 0.9rem; color: var(--clr-text-muted);">
                <span>Weight-based Shipping</span>
                <span>₹<%= order.shipping.toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></span>
            </div>
            <div class="summary-row total-row" style="display: flex; justify-content: space-between; font-size: 1.1rem; font-weight: bold; border-top: 1px solid var(--clr-border); padding-top: 8px; margin-top: 8px; color: var(--clr-whatsapp-dark);">
                <span>Total Paid</span>
                <span>₹<%= order.total.toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></span>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="receipt-actions no-print">
        <button onclick="window.print()" class="btn" style="background: var(--clr-primary); color: #fff; border-radius: var(--radius-sm); padding: 12px 28px; box-shadow: var(--shadow-md); display: inline-flex; align-items: center; gap: 8px; cursor: pointer; border: none;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"></polyline><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect x="6" y="14" width="12" height="8"></rect></svg>
            Print Receipt
        </button>
        <a href="/" style="align-self: center; font-size: 0.9rem; color: var(--clr-text-muted); text-decoration: underline; margin-left: 16px;">Go to Home Page</a>
    </div>
</div>

<%- include('partials/footer') %>
