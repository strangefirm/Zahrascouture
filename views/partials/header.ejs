<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : "Zahra's Couture — Premium Women's Ethnic Wear" %></title>
    <meta name="description" content="Zahra's Couture offers beautifully crafted salwar kameez, anarkali suits, and ethnic wear for women in Tamil Nadu. Shop premium Indian clothing with doorstep delivery.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <% if (typeof extraStyles !== 'undefined') { %>
        <link rel="stylesheet" href="<%= extraStyles %>">
    <% } %>
</head>
<body>

    <!-- ===== NAVBAR ===== -->
    <nav class="navbar scrolled" id="navbar">
        <div class="container nav-container">
            <a href="/" class="nav-brand">Zahra's <span>Couture</span></a>
            <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation">
                <span></span><span></span><span></span>
            </button>
            <ul class="nav-links" id="navLinks">
                <li><a href="/">Home</a></li>
                <li><a href="/shop">Shop Collections</a></li>
                <li><a href="/cart" class="cart-nav-link">Cart (<span id="cartNavCount">0</span>)</a></li>
                <% if (session && session.isAdmin) { %>
                    <li><a href="/admin/dashboard" style="color: var(--clr-accent) !important; font-weight:600;">Admin Dashboard</a></li>
                <% } %>
                <li><a href="https://wa.me/918939190164?text=Hi%20Zahra's%20Couture!" class="nav-cta" target="_blank" rel="noopener">Shop on WhatsApp</a></li>
            </ul>
        </div>
    </nav>
