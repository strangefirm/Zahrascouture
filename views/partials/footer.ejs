    <script>
        // Update nav cart count badge on load
        function updateNavCartBadge() {
            try {
                const cart = JSON.parse(localStorage.getItem('zahras_cart')) || [];
                const count = cart.reduce((total, item) => total + parseInt(item.quantity || 1), 0);
                const badge = document.getElementById('cartNavCount');
                if (badge) badge.textContent = count;
            } catch(e) {}
        }
        document.addEventListener('DOMContentLoaded', updateNavCartBadge);
        window.addEventListener('storage', updateNavCartBadge);
    </script>
