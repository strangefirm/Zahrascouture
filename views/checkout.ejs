<%- include('partials/header', { extraStyles: '/css/shop.css' }) %>

<div class="checkout-page container">
    <div class="checkout-header">
        <span class="section-tag">Order Details</span>
        <h1>Secure Checkout</h1>
    </div>

    <div class="checkout-layout">
        <!-- Form Section -->
        <form id="checkoutForm" class="checkout-form">
            <h2>Shipping Information</h2>
            
            <div class="form-group">
                <label for="customer_name">Full Name <span class="required">*</span></label>
                <input type="text" id="customer_name" required placeholder="Enter your full name">
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="customer_phone">Phone Number <span class="required">*</span></label>
                    <input type="tel" id="customer_phone" required placeholder="e.g. +91 9876543210">
                </div>
                <div class="form-group">
                    <label for="customer_email">Email Address</label>
                    <input type="email" id="customer_email" placeholder="e.g. name@example.com (optional)">
                </div>
            </div>

            <div class="form-group">
                <label for="customer_address">Delivery Address <span class="required">*</span></label>
                <textarea id="customer_address" required rows="3" placeholder="Apartment, Street address, Landmark, Area"></textarea>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="city">City <span class="required">*</span></label>
                    <input type="text" id="city" required placeholder="City">
                </div>
                <div class="form-group">
                    <label for="pincode">Pincode <span class="required">*</span></label>
                    <input type="text" id="pincode" required pattern="[0-9]{6}" placeholder="6-digit pincode">
                </div>
            </div>

            <div class="checkout-actions">
                <button type="submit" class="btn btn-primary place-order-btn">
                    Generate Invoice & Place Order
                </button>
            </div>
            
            <div id="checkoutError" class="checkout-error" style="display: none;"></div>
        </form>

        <!-- Sidebar Summary -->
        <div class="checkout-summary">
            <h3>Items in Order</h3>
            <div class="checkout-items-list" id="checkoutItemsList">
                <!-- Rendered by JS -->
            </div>
            <div class="summary-totals">
                <div class="summary-row">
                    <span>Subtotal</span>
                    <span id="checkoutSubtotal">₹0.00</span>
                </div>
                <div class="summary-row">
                    <span>Weight-based Shipping</span>
                    <span id="checkoutShipping">Calculating...</span>
                </div>
                <div class="summary-row total-row">
                    <span>Grand Total</span>
                    <span id="checkoutTotal">₹0.00</span>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
