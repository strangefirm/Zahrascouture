<%- include('../partials/admin-header', { title: title + ' — Zahra\'s Couture Admin' }) %>

<div class="admin-product-form-page">
    <div class="admin-header-row">
        <div>
            <h1><%= title %></h1>
            <p class="subtitle">Enter the details of the product to display in the shop.</p>
        </div>
        <div>
            <a href="/admin/products" class="btn btn-secondary" style="padding: 10px 20px;">Back to Sheet</a>
        </div>
    </div>

    <div class="admin-section-box form-container-box">
        <form action="/admin/products<%= product ? '/' + product.id : '' %>" method="POST" enctype="multipart/form-data" class="admin-form">
            
            <div class="form-row">
                <div class="form-group flex-2">
                    <label for="name">Product Name <span class="required">*</span></label>
                    <input type="text" id="name" name="name" required value="<%= product ? product.name : '' %>" placeholder="e.g. Burgundy Elegance Salwar Kameez">
                </div>
                <div class="form-group flex-1">
                    <label for="category">Category <span class="required">*</span></label>
                    <select id="category" name="category" required>
                        <option value="" disabled <%= !product ? 'selected' : '' %>>Select Category</option>
                        <option value="salwar" <%= product && product.category === 'salwar' ? 'selected' : '' %>>Salwar Kameez</option>
                        <option value="anarkali" <%= product && product.category === 'anarkali' ? 'selected' : '' %>>Anarkali Suit</option>
                        <option value="palazzo" <%= product && product.category === 'palazzo' ? 'selected' : '' %>>Palazzo Set</option>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label for="description">Description <span class="required">*</span></label>
                <textarea id="description" name="description" rows="4" required placeholder="Describe the design, styling details, occasion recommendations, etc."><%= product ? product.description : '' %></textarea>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="price">Price (₹) <span class="required">*</span></label>
                    <input type="number" step="0.01" min="0" id="price" name="price" required value="<%= product ? product.price : '' %>" placeholder="e.g. 1899">
                </div>
                <div class="form-group flex-2">
                    <label>Available Stock per Size <span class="required">*</span></label>
                    <div style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px;">
                        <% ['S', 'M', 'L', 'XL', 'XXL'].forEach(size => { 
                             let sizeVal = 0;
                             if (product && product.stock) {
                               if (typeof product.stock === 'object') {
                                 sizeVal = product.stock[size] !== undefined ? product.stock[size] : 0;
                               } else if (typeof product.stock === 'number' && (product.size || '').includes(size)) {
                                 sizeVal = product.stock;
                               }
                             }
                        %>
                            <div class="size-stock-input-wrapper" style="display:flex; flex-direction:column; gap:4px;">
                                <label for="stock_<%= size %>" style="font-size:0.85rem; font-weight:600; color:var(--clr-text-light); text-align:center;"><%= size %></label>
                                <input type="number" min="0" id="stock_<%= size %>" name="stock_<%= size %>" 
                                       value="<%= sizeVal %>" placeholder="0" 
                                       style="padding: 10px; border-radius: var(--radius-sm); border: 1px solid var(--clr-border); text-align:center;">
                            </div>
                        <% }) %>
                    </div>
                </div>
                <div class="form-group">
                    <label for="weight">Weight (grams) <span class="required">*</span></label>
                    <input type="number" min="0" id="weight" name="weight" required value="<%= product ? product.weight : '500' %>" placeholder="e.g. 600">
                    <small style="color:var(--clr-text-light); margin-top:2px;">Used to calculate shipping cost (default 500g)</small>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="size">Available Sizes</label>
                    <input type="text" id="size" name="size" value="<%= product ? product.size : 'S,M,L,XL,XXL' %>" placeholder="e.g. S,M,L,XL (comma-separated)">
                </div>
                <div class="form-group">
                    <label for="fabric">Fabric</label>
                    <input type="text" id="fabric" name="fabric" value="<%= product ? product.fabric : '' %>" placeholder="e.g. Pure Cotton, Silk, Georgette">
                </div>
                <div class="form-group">
                    <label for="color">Color</label>
                    <input type="text" id="color" name="color" value="<%= product ? product.color : '' %>" placeholder="e.g. Deep Rose, Burgundy">
                </div>
            </div>

            <div class="form-group">
                <label for="image">Product Image</label>
                <div class="upload-container">
                    <input type="file" id="image" name="image" accept="image/*" onchange="previewImage(this)">
                    <div class="upload-placeholder">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
                        <span>Click to upload image or drag and drop</span>
                    </div>
                </div>
                
                <div class="image-preview-block" id="imagePreviewContainer" style="<%= product ? 'display:block;' : 'display:none;' %>">
                    <p>Current/Preview Image:</p>
                    <img id="imagePreview" src="<%= product ? (product.image.startsWith('product-') ? '/images/uploads/' + product.image : '/images/' + product.image) : '' %>" class="form-img-preview" alt="Preview">
                </div>
            </div>

            <% if (product) { %>
                <div class="form-group checkbox-group">
                    <input type="checkbox" id="is_active" name="is_active" <%= product.is_active === 1 ? 'checked' : '' %>>
                    <label for="is_active">Make product active (visible in shop)</label>
                </div>
            <% } %>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary" style="padding: 12px 32px;"><%= product ? 'Update Product' : 'Upload Product' %></button>
                <a href="/admin/products" class="btn btn-secondary" style="border-color:var(--clr-border);">Cancel</a>
            </div>
            
        </form>
    </div>
</div>

<script>
    function previewImage(input) {
        const preview = document.getElementById('imagePreview');
        const container = document.getElementById('imagePreviewContainer');
        
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            
            reader.onload = function(e) {
                preview.src = e.target.result;
                container.style.display = 'block';
            }
            
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>
