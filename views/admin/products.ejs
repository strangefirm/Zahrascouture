<%- include('../partials/admin-header', { title: 'Product Sheet — Zahra\'s Couture Admin' }) %>

<div class="admin-products-sheet">
    <div class="admin-header-row">
        <div>
            <h1>Product Worksheet</h1>
            <p class="subtitle">Quickly manage stock, prices, and upload new collections in a spreadsheet-like sheet.</p>
        </div>
        <div class="quick-actions">
            <a href="/admin/products/new" class="btn btn-primary">+ Upload New Product</a>
        </div>
    </div>

    <!-- Product Table Sheet -->
    <div class="admin-section-box">
        <div class="sheet-info-tip no-print">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
            <span><strong>Tip:</strong> Click on any product's <strong>Price</strong> or <strong>Stock</strong> cell to edit inline. Press <strong>Tab</strong> or click outside to auto-save!</span>
        </div>

        <div class="table-responsive">
            <table class="admin-table sheet-table">
                <thead>
                    <tr>
                        <th style="width: 80px;">Thumbnail</th>
                        <th>Product Details</th>
                        <th>Category</th>
                        <th style="width: 140px;">Price (₹)</th>
                        <th style="min-width: 220px;">Stock (Qty)</th>
                        <th style="width: 110px;">Weight (grams)</th>
                        <th>Status</th>
                        <th style="width: 150px;" class="no-print">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% products.forEach(product => { %>
                        <tr id="prod-row-<%= product.id %>">
                            <td>
                                <img src="<%= product.image.startsWith('product-') ? '/images/uploads/' + product.image : '/images/' + product.image %>" class="sheet-thumb" alt="Product">
                            </td>
                            <td>
                                <div class="sheet-title"><strong><%= product.name %></strong></div>
                                <div class="sheet-meta">
                                    <% if (product.fabric) { %><span class="spec-tag">Fabric: <%= product.fabric %></span><% } %>
                                    <% if (product.size) { %><span class="spec-tag">Sizes: <%= product.size %></span><% } %>
                                </div>
                            </td>
                            <td>
                                <span class="category-pill pill-<%= product.category %>"><%= product.category.toUpperCase() %></span>
                            </td>
                            <td>
                                <div class="inline-input-wrapper">
                                    <input type="number" step="0.01" class="sheet-input inline-price" 
                                           value="<%= product.price %>" 
                                           data-id="<%= product.id %>"
                                           onblur="quickSave(<%= product.id %>)">
                                </div>
                            </td>
                            <td>
                                <div class="size-stock-inline-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(40px, 1fr)); gap: 4px;">
                                    <% 
                                      const activeSizes = (product.size || 'M').split(',').map(s => s.trim().toUpperCase()).filter(Boolean);
                                      activeSizes.forEach(size => {
                                        let sizeVal = 0;
                                        if (product.stock) {
                                          if (typeof product.stock === 'object') {
                                            sizeVal = product.stock[size] !== undefined ? product.stock[size] : 0;
                                          } else if (typeof product.stock === 'number') {
                                            sizeVal = product.stock;
                                          }
                                        }
                                    %>
                                        <div class="inline-size-input-wrapper" style="display: flex; flex-direction: column; align-items: center; background: #f7fafc; padding: 2px; border-radius: 4px; border: 1px solid #e2e8f0;">
                                            <span style="font-size: 0.7rem; font-weight: bold; color: #718096;"><%= size %></span>
                                            <input type="number" min="0" class="sheet-input inline-stock-size" 
                                                   style="width: 100%; border: none; background: transparent; text-align: center; padding: 2px 0; font-size: 0.85rem;" 
                                                   value="<%= sizeVal %>" 
                                                   data-id="<%= product.id %>"
                                                   data-size="<%= size %>"
                                                   onblur="quickSave(<%= product.id %>)">
                                        </div>
                                    <% }) %>
                                </div>
                            </td>
                            <td>
                                <span><%= product.weight %>g</span>
                            </td>
                            <td>
                                <span class="status-indicator <%= product.is_active === 1 ? 'active' : 'inactive' %>">
                                    <%= product.is_active === 1 ? 'Active' : 'Hidden' %>
                                </span>
                            </td>
                            <td class="no-print">
                                <div class="sheet-actions">
                                    <a href="/admin/products/<%= product.id %>/edit" class="action-btn-edit">Edit Form</a>
                                    
                                    <form action="/admin/products/<%= product.id %>/delete" method="POST" 
                                          onsubmit="return confirm('Are you sure you want to delete this product? This action cannot be undone.');" 
                                          style="display:inline;">
                                        <button type="submit" class="action-btn-delete">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<%- include('../partials/admin-footer') %>
